{
  "name": "exit-gate",
  "version": "0.1.0",
  "description": "Linux Application Firewall with eBPF",
  "main": "dist/main.js",
  "author": "Exit Gate Contributors",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "tsc && electron .",
    "build": "tsc && vite build",
    "package": "electron-builder",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "@mui/material": "^5.15.0",
    "@mui/icons-material": "^5.15.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "concurrently": "^8.2.0"
  },
  "build": {
    "appId": "com.exitgate.firewall",
    "productName": "Exit Gate",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../daemon/target/release/exit-gate-daemon",
        "to": "daemon/exit-gate-daemon"
      }
    ]
  }
}
